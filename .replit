modules = ["nodejs-22", "postgresql-16"]
[nix]
channel = "stable-25_05"
packages = ["unzip"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Discord Bot"

[[workflows.workflow]]
name = "Discord Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd chrxmee-ai && node index.js"

[workflows.workflow.metadata]
outputType = "console"

[userenv]

[userenv.shared]
CLIENT_ID = "1458944258454065377"

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "cd chrxmee-ai && node index.js"]
